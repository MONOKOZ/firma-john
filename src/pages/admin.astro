---
import Layout from '../layouts/Layout.astro';
import { AdminDashboardWithProvider } from '../components/AdminDashboard';
---

<Layout title="Meister-Backend // Firma JOHN">
  <main class="w-full max-w-7xl mx-auto px-6 sm:px-10 py-12 md:py-24">
    <!-- Link to Homepage -->
    <div class="mb-8">
      <a href="/" class="inline-flex items-center text-xs font-bold uppercase tracking-wider text-stone-500 hover:text-[#ff4c00] transition-colors gap-2">
        ← Zurück zur Homepage
      </a>
    </div>

    <!-- Admin dashboard container wrapped in a single Client-Only React component to share context -->
    <AdminDashboardWithProvider client:only="react" />
  </main>
</Layout>
