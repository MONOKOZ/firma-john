---
import Layout from '../layouts/Layout.astro';
import { getContent } from '../lib/sheets/read';

// Build-Zeit: echte Sheet-Inhalte via Service Account; Fallback auf data.ts-Defaults.
const content = await getContent();
const DEFAULT_ALLGEMEIN = content.allgemeines;
const TEAM_MEMBERS = content.team;
const HISTORY_MILESTONES = content.historie;
const SERVICE_CATEGORIES = content.dienstleistungen;
const JOB_VACANCIES = content.jobs;
---

<Layout title="Firma JOHN | Gas · Wasser · Heizung · Sanitär Ludwigsfelde">
  <!-- Dynamic Background Noise Line or Branding Bar - Re-engineered for freshness -->
  <div class="w-full bg-[#121315] text-white py-3 px-6 border-b border-[#24262b] text-center flex items-center justify-center space-x-3 text-meta-label">
    <span class="inline-block h-2 w-2 rounded-full bg-[#ff4c00] animate-pulse"></span>
    <span class="font-semibold text-white">45 Jahre Meisterqualität</span>
    <span class="hidden md:inline-block text-[#9a9ba0]">•</span>
    <span class="hidden md:inline-block text-[#9a9ba0]">Ludwigsfelde & Berlin-Brandenburg</span>
    <span class="hidden sm:inline-block text-[#ff4c00]/90 font-bold bg-[#ff4c00]/10 px-2.5 py-1 rounded border border-[#ff4c00]/20">Familienbetrieb seit 1981</span>
  </div>

  <!-- Primary Sticky Header - Ultra Clean Awwwards Aesthetic -->
  <header class="sticky top-0 z-50 bg-[#fafaf7]/85 backdrop-blur-md border-b border-[#121315]/10">
    <div class="max-w-7xl mx-auto px-6 sm:px-10 h-24 flex items-center justify-between">
      
      <!-- Brand Logo -->
      <a href="#" class="flex items-baseline space-x-2 text-[#121315] hover:opacity-90">
        <span class="font-serif text-3xl sm:text-4xl font-black tracking-tight">JOHN</span>
        <span class="text-meta-label text-[#ff4c00] font-black">Haustechnik</span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center space-x-10">
        <a href="#services" class="text-[#121315]/70 hover:text-[#121315] text-sm font-semibold tracking-wide transition-colors relative py-2 group">
          Leistungen
          <span class="absolute bottom-0 left-0 w-0 h-[2px] bg-[#ff4c00] transition-all duration-300 group-hover:w-full"></span>
        </a>
        <a href="#team" class="text-[#121315]/70 hover:text-[#121315] text-sm font-semibold tracking-wide transition-colors relative py-2 group">
          Menschen & Team
          <span class="absolute bottom-0 left-0 w-0 h-[2px] bg-[#ff4c00] transition-all duration-300 group-hover:w-full"></span>
        </a>
        <a href="#historie" class="text-[#121315]/70 hover:text-[#121315] text-sm font-semibold tracking-wide transition-colors relative py-2 group">
          Geschichte
          <span class="absolute bottom-0 left-0 w-0 h-[2px] bg-[#121315] transition-all duration-300 group-hover:w-full"></span>
        </a>
        <a href="#karriere" class="text-[#ff4c00] hover:text-[#ff4c00]/80 text-sm font-bold tracking-wide transition-colors flex items-center bg-[#ff4c00]/5 px-3.5 py-1.5 rounded-full border border-[#ff4c00]/10">
          <span>Karriere</span>
          <span class="ml-2 px-1.5 py-0.5 bg-[#ff4c00] text-white text-[9px] font-mono rounded-full font-bold uppercase tracking-wider">Jobs</span>
        </a>
      </nav>

      <!-- Contact Core CTA (Desktop) -->
      <div class="hidden md:flex items-center space-x-6">
        <a 
          href={`tel:${DEFAULT_ALLGEMEIN.contact_phone.replace(/\s+/g, "")}`} 
          class="text-[#121315]/80 hover:text-[#121315] text-right transition-colors"
          data-cms-href="contact_phone"
        >
          <span class="block text-[9px] text-[#9a9ba0] uppercase tracking-widest font-bold">Notruf & Büro</span>
          <span class="font-mono font-bold text-sm text-[#121315]" data-cms="contact_phone">{DEFAULT_ALLGEMEIN.contact_phone}</span>
        </a>
        <a 
          href="#anfrage" 
          class="inline-flex items-center justify-center px-6 h-12 bg-[#ff4c00] hover:bg-[#ff4c00]/90 text-white font-bold text-xs uppercase tracking-widest rounded-full transition-all duration-300 shadow-sm hover:scale-[1.02] active:scale-[0.98]"
        >
          Projekt Planen
        </a>
      </div>

      <!-- Mobile Menu Toggle Button -->
      <button 
        id="mobile-menu-toggle"
        type="button" 
        class="md:hidden flex h-12 w-12 items-center justify-center border border-[#121315]/15 hover:border-[#121315]/30 rounded-full text-[#121315] transition-colors cursor-pointer"
        aria-label="Menü öffnen"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation Drawer -->
    <div 
      id="mobile-drawer"
      class="hidden border-t border-[#121315]/10 overflow-hidden bg-[#fafaf7] shadow-xl absolute top-24 left-0 w-full z-40 transition-all duration-300"
    >
      <div class="px-6 py-8 flex flex-col space-y-6">
        <a 
          href="#services" 
          class="text-xl font-bold text-[#121315] hover:text-[#ff4c00]"
        >
          Dienstleistungen & Spektrum
        </a>
        <a 
          href="#team" 
          class="text-xl font-bold text-[#121315] hover:text-[#ff4c00]"
        >
          Menschen hinter der Technik
        </a>
        <a 
          href="#historie" 
          class="text-xl font-bold text-[#121315] hover:text-[#ff4c00]"
        >
          Über 45 Jahre Historie
        </a>
        <a 
          href="#karriere" 
          class="text-xl font-bold text-[#ff4c00] hover:underline flex items-center"
        >
          Jobs & Ausbildung @ JOHN
        </a>

        <div class="pt-6 border-t border-[#121315]/10 space-y-4 font-sans text-left">
          <div class="text-sm flex items-center space-x-3">
            <svg class="w-4 h-4 text-[#ff4c00]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href={`tel:${DEFAULT_ALLGEMEIN.contact_phone.replace(/\s+/g, "")}`} class="font-bold text-[#121315] font-mono text-base" data-cms-href="contact_phone" data-cms="contact_phone">{DEFAULT_ALLGEMEIN.contact_phone}</a>
          </div>
          <div class="text-sm flex items-center space-x-3">
            <svg class="w-4 h-4 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="font-medium text-[#121315]/80" data-cms="contact_address">{DEFAULT_ALLGEMEIN.contact_address}</span>
          </div>
          <a 
            href="#anfrage" 
            class="w-full h-12 inline-flex items-center justify-center bg-[#121315] text-white font-bold text-xs uppercase tracking-widest rounded-full"
          >
            Kostenfreie Beratung planen
          </a>
        </div>
      </div>
    </div>
  </header>

  <!-- HERO SECTION: Pure Typographic, High-End Architectural Poster -->
  <section class="relative px-6 sm:px-10 py-20 sm:py-32 md:py-44 max-w-7xl mx-auto w-full overflow-hidden">
    <!-- Abstract structural grid guidelines representing precision engineering -->
    <div class="absolute inset-x-0 top-0 h-[120%] pointer-events-none opacity-5 border-x border-[#121315]/10 max-w-7xl mx-auto flex justify-between z-0">
      <div class="w-[1px] h-full bg-[#121315]"></div>
      <div class="w-[1px] h-full bg-[#121315] hidden sm:block"></div>
      <div class="w-[1px] h-full bg-[#121315] hidden md:block"></div>
      <div class="w-[1px] h-full bg-[#121315]"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-12 items-start relative z-10">
      
      <!-- Typographic Hero Wing -->
      <div class="lg:col-span-7 flex flex-col justify-center">
        <div>
          <div class="flex items-center space-x-3 mb-8">
            <span class="h-[2px] w-12 bg-[#ff4c00]"></span>
            <span class="text-meta-label text-[#ff4c00] font-black">
              Haustechnik mit Unterschrift
            </span>
          </div>
          
          <!-- Clamp Typography Display Header -->
          <h1 class="text-display-title font-black text-stone-950 text-left mb-10" data-cms="hero_title">
            Meisterliche<br />
            <span class="text-[#ff4c00]">Haustechnik</span> &<br />
            Bäder.
          </h1>
        </div>

        <div class="space-y-8 text-left">
          <p class="text-[#121315]/80 text-body-editorial max-w-[580px]" data-cms="hero_subtitle">
            {DEFAULT_ALLGEMEIN.hero_subtitle}
          </p>
          
          <!-- Call to Actions alignment -->
          <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4 pt-4">
            <a 
              href="#anfrage" 
              class="inline-flex items-center justify-center px-10 h-14 bg-[#ff4c00] hover:bg-[#ff4c00]/95 text-white font-bold text-xs uppercase tracking-widest rounded-full transition-all duration-300 shadow-sm"
            >
              Express-Anfrage senden
            </a>
            <a 
              href="#services" 
              class="inline-flex items-center justify-center px-8 h-14 bg-white hover:bg-stone-50 text-[#121315] border border-[#121315]/15 font-bold text-xs uppercase tracking-widest rounded-full transition-all duration-300"
            >
              Leistungsspektrum
            </a>
          </div>
        </div>
      </div>

      <!-- Real-Time Metrics Wing -->
      <div class="lg:col-span-5 lg:pl-8">
        <div class="w-full bg-white border-2 border-[#121315] rounded-3xl p-8 sm:p-10 shadow-[6px_6px_0px_0px_rgba(18,19,21,1)] relative overflow-hidden text-left">
          
          <!-- Title Gauge -->
          <div class="flex items-center justify-between mb-8 border-b border-stone-100 pb-6">
            <h3 class="font-serif text-xl sm:text-2xl font-bold text-[#121315] tracking-tight">Meister-Messer</h3>
            <span class="text-[10px] uppercase font-mono tracking-widest text-[#ff4c00] px-2.5 py-0.5 bg-[#ff4c00]/10 rounded-full font-bold">Technik-Ticker</span>
          </div>

          <div class="space-y-6">
            <!-- Parameter 1 -->
            <div>
              <span class="text-[10px] uppercase font-mono text-stone-400 tracking-wider">Erfahrung</span>
              <div class="text-3xl font-serif font-black text-[#121315]" data-cms="experience_stat">{DEFAULT_ALLGEMEIN.experience_stat}</div>
              <p class="text-xs text-stone-500 mt-1">Gegründet 1981 in Ludwigsfelde</p>
            </div>

            <!-- Div bar -->
            <div class="h-[1px] bg-stone-150"></div>

            <!-- Parameter 2 -->
            <div>
              <span class="text-[10px] uppercase font-mono text-stone-400 tracking-wider">Kundenzufriedenheit</span>
              <div class="text-3xl font-serif font-black text-[#ff4c00]" data-cms="success_stat">{DEFAULT_ALLGEMEIN.success_stat}</div>
              <p class="text-xs text-stone-500 mt-1">Echte Meisterleistung mit Gewährleistung</p>
            </div>

            <!-- Div bar -->
            <div class="h-[1px] bg-stone-150"></div>

            <!-- Parameter 3 -->
            <div>
              <span class="text-[10px] uppercase font-mono text-stone-400 tracking-wider">Analoger Notdienst</span>
              <div class="text-sm font-bold text-stone-700 font-mono flex items-center gap-2">
                <span class="h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span>
                <span data-cms="notdienst_phone">{DEFAULT_ALLGEMEIN.notdienst_phone}</span>
              </div>
              <p class="text-xs text-stone-500 mt-1">Soforthilfe bei massiven Wasserschäden vor Ort</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WORK SPECTRUM: The Full-Width Solid Dark Block offering rich spatial rhythm -->
  <section id="services" class="bg-[#121315] text-[#fafaf7] py-24 sm:py-36 relative overflow-hidden">
    <!-- Starburst ambient light effect -->
    <div class="absolute -right-36 -top-36 h-96 w-96 rounded-full bg-[#ff4c00]/10 blur-[100px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 sm:px-10 relative z-10">
      
      <div class="mb-20 grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <div class="lg:col-span-8">
          <span class="text-meta-label text-[#ff4c00] font-black block mb-4">
            Unser Leistungsspektrum
          </span>
          <h2 class="text-section-header text-white font-black">
            Planung, Modernisierung & Handwerkliche Instandhaltung.
          </h2>
        </div>
        <div class="lg:col-span-4 lg:pt-8">
          {/* Strict reading limit container */}
          <p class="text-stone-400 text-body-editorial max-w-[580px]">
            Ob Komplettbäder fürs Alter, zukunftssichere Wärmepumpen oder regelmäßige Gas-Sicherheitschecks. Nutzen Sie die Kategorien unten, um nähere Details und den zuständigen Meister zu erfahren.
          </p>
        </div>
      </div>

      <!-- Grid of Services Categories -->
      <div id="services-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {SERVICE_CATEGORIES.map((category) => (
          <div class="bg-[#1c1d21] border border-stone-800 rounded-3xl p-8 hover:border-[#ff4c00]/40 transition-luxury flex flex-col justify-between min-h-[380px] group text-left">
            <div>
              <div class="w-12 h-12 rounded-full bg-[#ff4c00]/10 flex items-center justify-center text-[#ff4c00] mb-8 group-hover:scale-110 transition-transform duration-300">
                {category.id === "sanitaer" && (
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                  </svg>
                )}
                {category.id === "heizung" && (
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048" />
                  </svg>
                )}
                {category.id === "lueftung" && (
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1" />
                  </svg>
                )}
                {category.id === "solar" && (
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1" />
                  </svg>
                )}
              </div>
              <h3 class="text-xl font-bold mb-4">{category.title}</h3>
              <p class="text-stone-400 text-sm leading-relaxed mb-6">{category.description}</p>
            </div>
            <div>
              <ul class="space-y-2 mb-6 border-t border-stone-800 pt-4">
                {category.details[0].bullets.slice(0, 3).map((bullet) => (
                  <li class="text-xs text-stone-500 flex items-start gap-2">
                    <span class="text-[#ff4c00] mt-0.5">•</span>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
              <a href="#anfrage" class="inline-flex items-center text-xs font-mono font-bold text-[#ff4c00] tracking-wider uppercase group-hover:translate-x-1 transition-transform">
                Anfragen &nbsp;→
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TEAM SECTION: Human Authenticity & Portrait Cards -->
  <section id="team" class="py-24 sm:py-36 bg-[#fafaf7] relative overflow-hidden text-left">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">
      
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start mb-20">
        <div class="lg:col-span-6">
          <span class="text-meta-label text-[#ff4c00] font-black block mb-4">
            Familienschlagkraft
          </span>
          <h2 class="text-section-header text-[#121315] font-black mb-6">
            Menschen, die Ihr Vertrauen verdienen.
          </h2>
          <div class="h-2 w-20 bg-[#ff4c00]"></div>
        </div>

        <div class="lg:col-span-6 text-stone-600 lg:pt-10">
          <p class="text-body-editorial max-w-[580px]">
            In einer Zeit des unpersönlichen Internet-Auftritts setzen wir bewusst ein Zeichen. Wir schicken keine wechselnden Subunternehmer, sondern verlässliche Gesichter mit Brief und Siegel. Lernen Sie die Menschen kennen, die täglich bei Ihnen vor Ort sind.
          </p>
        </div>
      </div>

      <div id="team-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
        {TEAM_MEMBERS.map((member) => (
          <div class="bg-white border border-stone-200 rounded-3xl overflow-hidden hover:shadow-md transition-luxury flex flex-col justify-between">
            <div class="relative aspect-square overflow-hidden bg-stone-100">
              <img 
                class="w-full h-full object-cover object-center grayscale hover:grayscale-0 transition-all duration-700" 
                src={member.imageUrl} 
                alt={member.name} 
              />
              <div class="absolute bottom-4 left-4 right-4 bg-white/95 backdrop-blur-sm p-4 rounded-xl border border-stone-100 shadow-sm">
                <span class="text-[9px] font-mono uppercase tracking-widest text-stone-400">Seit {member.experienceYear} im Team</span>
                <h4 class="text-lg font-bold text-stone-1000 mt-1">{member.name}</h4>
                <p class="text-xs text-[#ff4c00] font-semibold mt-0.5">{member.role}</p>
              </div>
            </div>
            <div class="p-8 flex flex-col justify-between flex-grow">
              <blockquote class="text-stone-600 italic text-sm mb-6 relative">
                "{member.quote}"
              </blockquote>
              <p class="text-xs text-stone-500 leading-relaxed font-sans border-t border-stone-100 pt-4">
                {member.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CHRONICLE TIMELINE: Bold Vintage Graphic -->
  <section id="historie" class="bg-[#121315] text-[#fafaf7] py-24 sm:py-36 relative overflow-hidden text-left">
    <div class="max-w-7xl mx-auto px-6 sm:px-10 relative z-10">
      
      <div class="mb-24 text-center">
        <span class="text-meta-label text-[#ff4c00] font-black block mb-4">
          Präzision in Generationen
        </span>
        <h2 class="text-section-header font-black text-white mb-6">
          Unsere Historie als Zollstock-Chronik
        </h2>
        <p class="text-stone-400 text-body-editorial max-w-[580px] mx-auto">
          Seit 1981 messen wir Millimeter für Millimeter höchste Kundenzufriedenheit. Unser "Zollstock"-Maßband zeigt die wichtigsten Meilensteine.
        </p>
      </div>

      <!-- Main vertical line -->
      <div id="history-container" class="relative border-l border-stone-800 max-w-3xl mx-auto pl-8 sm:pl-12 space-y-16">
        {HISTORY_MILESTONES.map((milestone) => (
          <div class="relative group">
            <div class="absolute -left-[45px] sm:-left-[61px] top-1.5 w-6 h-6 rounded-full bg-[#121315] border-2 border-[#ff4c00] flex items-center justify-center group-hover:bg-[#ff4c00] transition-colors duration-300">
              <div class="w-2 h-2 rounded-full bg-[#ff4c00] group-hover:bg-white transition-colors duration-300"></div>
            </div>
            <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-6 mb-2">
              <span class="text-3xl font-serif font-black text-[#ff4c00] leading-none">{milestone.year}</span>
              <h4 class="text-xl font-bold text-white">{milestone.title}</h4>
            </div>
            <p class="text-stone-400 text-sm leading-relaxed max-w-2xl">{milestone.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CAREER SECTION: High-Contrast Grid Elements for Recruitment -->
  <section id="karriere" class="py-24 sm:py-36 bg-[#fafaf7] relative overflow-hidden text-left">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">
      
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start mb-20">
        <div class="lg:col-span-6">
          <span class="text-meta-label text-[#ff4c00] font-black block mb-4">
            Wachsen Sie mit uns!
          </span>
          <h2 class="text-section-header text-[#121315] font-black mb-6">
            Komm in's Team! <br />
            Alles im Griff.
          </h2>
        </div>

        <div class="lg:col-span-6 text-stone-600 lg:pt-10">
          <p class="text-body-editorial max-w-[580px] mb-6">
            Wir haken keine To-Do-Listen ab. Wir arbeiten verlässlich, familiär und auf Augenhöhe. Sie haben die Ausbildung, wir bieten den langfristig sicheren Heimathafen direkt in Ludwigsfelde – <strong>garantiert ohne Montagen oder unfaire Schichtdienste</strong>.
          </p>
          <p class="text-sm text-stone-400 font-mono italic">
            → Auch Ausbildungsbewerbungen sind jederzeit willkommen!
          </p>
        </div>
      </div>

      <!-- Job List Cards -->
      <div id="jobs-container" class="space-y-12">
        {JOB_VACANCIES.map((job) => (
          <div class="bg-white border border-stone-200 rounded-3xl p-8 sm:p-12 hover:shadow-md transition-luxury">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 border-b border-stone-100 pb-8 mb-8">
              <div>
                <span class="inline-block px-3 py-1 bg-stone-100 text-stone-600 text-[10px] font-mono uppercase tracking-wider rounded-full mb-3">
                  {job.type}
                </span>
                <h3 class="text-2xl font-bold text-stone-900">{job.title}</h3>
              </div>
              <a 
                href={`mailto:info@john-haustechnik.de?subject=Bewerbung%20als%20${encodeURIComponent(job.title)}`}
                class="inline-flex items-center justify-center px-6 h-12 bg-[#ff4c00] hover:bg-[#ff4c00]/90 text-white font-bold text-xs uppercase tracking-widest rounded-full transition-all duration-300"
              >
                Jetzt formlos bewerben
              </a>
            </div>

            <p class="text-stone-600 text-sm mb-8 leading-relaxed max-w-3xl">
              {job.intro}
            </p>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
              <div>
                <h4 class="text-xs font-mono uppercase tracking-wider text-stone-400 mb-4 font-bold">Was Sie mitbringen:</h4>
                <ul class="space-y-3">
                  {job.requirements.map((req) => (
                    <li class="text-sm text-stone-700 flex items-start gap-3">
                      <svg class="w-5 h-5 text-stone-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      <span>{req}</span>
                    </li>
                  ))}
                </ul>
              </div>
              <div>
                <h4 class="text-xs font-mono uppercase tracking-wider text-[#ff4c00] mb-4 font-bold">Was wir bieten:</h4>
                <ul class="space-y-3">
                  {job.benefits.map((benefit) => (
                    <li class="text-sm text-stone-700 flex items-start gap-3">
                      <svg class="w-5 h-5 text-emerald-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                      </svg>
                      <span>{benefit}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SIMPLE & OPTIMIZED DIRECT INQUIRY FORM -->
  <section id="anfrage" class="bg-[#fafaf7] pb-24 sm:pb-36 relative overflow-hidden text-left">
    <div class="max-w-4xl mx-auto px-6">
      <div class="bg-white border-2 border-[#121315] rounded-3xl p-8 sm:p-12 shadow-[6px_6px_0px_0px_rgba(18,19,21,1)]">
        <div class="text-center mb-12">
          <span class="text-meta-label text-[#ff4c00] font-black block mb-4">Direktanfrage</span>
          <h2 class="text-section-header text-[#121315] font-black mb-4">Projektanfrage starten</h2>
          <p class="text-stone-500 text-sm max-w-[500px] mx-auto leading-relaxed">
            Sende uns unverbindlich Deine Wünsche. Unser Büro meldet sich innerhalb von 24 Stunden bei Dir.
          </p>
        </div>

        <form id="direct-inquiry-form" class="space-y-6">
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <label class="cursor-pointer border-2 border-stone-200 rounded-2xl p-4 text-center hover:border-[#ff4c00] transition-colors relative flex flex-col items-center gap-2">
              <input type="radio" name="project_type" value="sanitaer" class="absolute top-4 right-4 accent-[#ff4c00]" checked />
              <svg class="w-6 h-6 text-[#ff4c00]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
              <span class="text-sm font-bold text-stone-900 mt-1">Bad / Sanitär</span>
            </label>
            <label class="cursor-pointer border-2 border-stone-200 rounded-2xl p-4 text-center hover:border-[#ff4c00] transition-colors relative flex flex-col items-center gap-2">
              <input type="radio" name="project_type" value="heizung" class="absolute top-4 right-4 accent-[#ff4c00]" />
              <svg class="w-6 h-6 text-[#ff4c00]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048" />
              </svg>
              <span class="text-sm font-bold text-stone-900 mt-1">Wärme / Heizung</span>
            </label>
            <label class="cursor-pointer border-2 border-stone-200 rounded-2xl p-4 text-center hover:border-[#ff4c00] transition-colors relative flex flex-col items-center gap-2">
              <input type="radio" name="project_type" value="klima" class="absolute top-4 right-4 accent-[#ff4c00]" />
              <svg class="w-6 h-6 text-[#ff4c00]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1" />
              </svg>
              <span class="text-sm font-bold text-stone-900 mt-1">Solar / Lüftung</span>
            </label>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label class="block text-xs font-mono uppercase tracking-wider text-stone-400 mb-2 font-bold">Dein Name *</label>
              <input type="text" required placeholder="Sven Muster" class="w-full h-12 px-4 rounded-xl border border-stone-200 focus:border-[#ff4c00] focus:outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-xs font-mono uppercase tracking-wider text-stone-400 mb-2 font-bold">Telefonnummer *</label>
              <input type="tel" required placeholder="0172 / 1234567" class="w-full h-12 px-4 rounded-xl border border-stone-200 focus:border-[#ff4c00] focus:outline-none transition-colors" />
            </div>
          </div>

          <div>
            <label class="block text-xs font-mono uppercase tracking-wider text-stone-400 mb-2 font-bold">E-Mail-Adresse *</label>
            <input type="email" required placeholder="sven@beispiel.de" class="w-full h-12 px-4 rounded-xl border border-stone-200 focus:border-[#ff4c00] focus:outline-none transition-colors" />
          </div>

          <div>
            <label class="block text-xs font-mono uppercase tracking-wider text-stone-400 mb-2 font-bold">Dein Anliegen / Projektbeschreibung</label>
            <textarea rows="4" placeholder="Beschreibe kurz Dein Vorhaben. Z.B. Heizungstausch, altersgerechter Badumbau, Notfall oder Wartung..." class="w-full p-4 rounded-xl border border-stone-200 focus:border-[#ff4c00] focus:outline-none transition-colors resize-none"></textarea>
          </div>

          <button id="inquiry-submit-btn" type="submit" class="w-full h-14 bg-[#ff4c00] hover:bg-[#ff4c00]/90 text-white font-bold text-xs uppercase tracking-widest rounded-xl transition-all duration-300 pointer-events-auto cursor-pointer">
            Anfrage absenden
          </button>
        </form>
        <div id="success-message" class="hidden mt-6 p-6 bg-emerald-50 border border-emerald-200 rounded-xl text-center text-emerald-800 text-sm font-medium">
          Vielen Dank! Deine Projektanfrage wurde erfolgreich übermittelt. Wir melden uns umgehend bei Dir.
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-[#121315] text-[#9a9ba0] pt-24 pb-12 border-t border-[#24262b] text-left">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-16 mb-16">
        <div class="md:col-span-4">
          <a href="#" class="flex items-baseline space-x-2 text-white hover:opacity-90 transition-opacity mb-6">
            <span class="font-serif text-3xl font-black tracking-tight">JOHN</span>
            <span class="text-meta-label text-[#ff4c00] font-black">Haustechnik</span>
          </a>
          <p class="text-xs text-stone-500 leading-relaxed max-w-[280px]">
            Firma Sven John e.K. — Ihr traditionsbewusster Meisterbetrieb für Gas, Wasser, Heizung, Sanitär, Lüftung & Solar in Brandenburg.
          </p>
        </div>

        <div class="md:col-span-4">
          <h4 class="text-xs font-mono uppercase tracking-wider text-white font-bold mb-6">Kontakt & Service</h4>
          <ul class="space-y-3 text-xs">
            <li data-cms="contact_address">Dornweg 14, 14974 Ludwigsfelde</li>
            <li>Notruf & Büro: <a href="tel:03378801127" class="text-white hover:underline font-mono" data-cms-href="contact_phone" data-cms="contact_phone">{DEFAULT_ALLGEMEIN.contact_phone}</a></li>
            <li>E-Mail: <a href="mailto:info@john-haustechnik.de" class="text-white hover:underline" data-cms-href="contact_email" data-cms="contact_email">{DEFAULT_ALLGEMEIN.contact_email}</a></li>
            <li class="pt-2 text-[10px] text-stone-500 font-mono" data-cms="contact_hours">{DEFAULT_ALLGEMEIN.contact_hours}</li>
          </ul>
        </div>

        <div class="md:col-span-4">
          <h4 class="text-xs font-mono uppercase tracking-wider text-white font-bold mb-6">Rechtliches</h4>
          <ul class="space-y-3 text-xs">
            <li><a href="#impressum" class="hover:text-white">Impressum</a></li>
            <li><a href="#datenschutz" class="hover:text-white">Datenschutzerklärung</a></li>
            <li><a href="#cookie-settings" class="hover:text-white">Cookie-Einstellungen</a></li>
            <li class="pt-4 text-[10px] text-[#ff4c00] font-bold">Eingetragen in der Handwerkskammer Potsdam</li>
          </ul>
        </div>
      </div>

      <div class="border-t border-stone-800 pt-8 flex flex-col sm:flex-row justify-between items-center text-[10px] uppercase font-mono tracking-wider text-stone-600 gap-4">
        <span>© 2026 Firma Sven John e.K. Alle Rechte vorbehalten.</span>
        <span>Meister seit 1981</span>
      </div>
    </div>
  </footer>

  <!-- Native, High-Performance Interactive Functions -->
  <script>
    // Safe vanilla mobile-menu drawer toggle
    const toggleBtn = document.getElementById('mobile-menu-toggle');
    const drawer = document.getElementById('mobile-drawer');
    if (toggleBtn && drawer) {
      toggleBtn.addEventListener('click', () => {
        drawer.classList.toggle('hidden');
      });
    }

    // Inquiry submission handler
    const inquiryForm = document.getElementById('direct-inquiry-form');
    const successMsg = document.getElementById('success-message');
    if (inquiryForm && successMsg) {
      inquiryForm.addEventListener('submit', (e) => {
        e.preventDefault();
        successMsg.classList.remove('hidden');
        inquiryForm.classList.add('hidden');
        successMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });
      });
    }

    // Dynamic Client-Side CMS Injection from local cache
    const cmsCacheStr = localStorage.getItem("john_haustechnik_cms_public_cache");
    if (cmsCacheStr) {
      try {
        const data = JSON.parse(cmsCacheStr);
        
        // 1. Process Allgemeines text content
        const cms = data.allgemeines;
        if (cms) {
          Object.keys(cms).forEach(key => {
            const val = cms[key];
            if (!val) return;
            
            // Text nodes
            document.querySelectorAll(`[data-cms="${key}"]`).forEach(el => {
              el.textContent = val;
            });
            
            // Link hrefs
            if (key === 'contact_phone') {
              document.querySelectorAll('[data-cms-href="contact_phone"]').forEach(el => {
                el.setAttribute('href', `tel:${val.trim().replace(/\s+/g, "")}`);
              });
            } else if (key === 'contact_email') {
              document.querySelectorAll('[data-cms-href="contact_email"]').forEach(el => {
                el.setAttribute('href', `mailto:${val.trim()}`);
              });
            }
          });
        }
        
        // 2. Re-render Service Categories
        const servicesContainer = document.getElementById('services-container');
        if (servicesContainer && data.dienstleistungen && Array.isArray(data.dienstleistungen)) {
          servicesContainer.innerHTML = data.dienstleistungen.map((cat: any) => {
            const bulletsHtml = cat.details && cat.details[0] && cat.details[0].bullets
              ? cat.details[0].bullets.slice(0, 3).map((b: any) => `
                  <li class="text-xs text-stone-500 flex items-start gap-2">
                    <span class="text-[#ff4c00] mt-0.5">•</span>
                    <span>${b}</span>
                  </li>
                `).join('')
              : '';
            
            let iconSvg = '';
            if (cat.id === 'sanitaer') {
              iconSvg = '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>';
            } else if (cat.id === 'heizung') {
              iconSvg = '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048" /></svg>';
            } else {
              iconSvg = '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1" /></svg>';
            }

            return `
              <div class="bg-[#1c1d21] border border-stone-800 rounded-3xl p-8 hover:border-[#ff4c00]/40 transition-luxury flex flex-col justify-between min-h-[380px] group text-left">
                <div>
                  <div class="w-12 h-12 rounded-full bg-[#ff4c00]/10 flex items-center justify-center text-[#ff4c00] mb-8 group-hover:scale-110 transition-transform duration-300">
                    ${iconSvg}
                  </div>
                  <h3 class="text-xl font-bold mb-4">${cat.title}</h3>
                  <p class="text-stone-400 text-sm leading-relaxed mb-6">${cat.description}</p>
                </div>
                <div>
                  <ul class="space-y-2 mb-6 border-t border-stone-800 pt-4">
                    ${bulletsHtml}
                  </ul>
                  <a href="#anfrage" class="inline-flex items-center text-xs font-mono font-bold text-[#ff4c00] tracking-wider uppercase group-hover:translate-x-1 transition-transform">
                    Anfragen &nbsp;→
                  </a>
                </div>
              </div>
            `;
          }).join('');
        }
        
        // 3. Re-render Team Members
        const teamContainer = document.getElementById('team-container');
        if (teamContainer && data.team && Array.isArray(data.team)) {
          teamContainer.innerHTML = data.team.map((member: any) => `
            <div class="bg-white border border-stone-200 rounded-3xl overflow-hidden hover:shadow-md transition-luxury flex flex-col justify-between">
              <div class="relative aspect-square overflow-hidden bg-stone-100">
                <img 
                  class="w-full h-full object-cover object-center grayscale hover:grayscale-0 transition-all duration-700" 
                  src="${member.imageUrl || 'https://images.unsplash.com/photo-1560250097-0b93528c311a?auto=format&fit=crop&q=80&w=600'}" 
                  alt="${member.name}" 
                />
                <div class="absolute bottom-4 left-4 right-4 bg-white/95 backdrop-blur-sm p-4 rounded-xl border border-stone-100 shadow-sm">
                  <span class="text-[9px] font-mono uppercase tracking-widest text-stone-400">Seit ${member.experienceYear} im Team</span>
                  <h4 class="text-lg font-bold text-stone-1000 mt-1">${member.name}</h4>
                  <p class="text-xs text-[#ff4c00] font-semibold mt-0.5">${member.role}</p>
                </div>
              </div>
              <div class="p-8 flex flex-col justify-between flex-grow">
                <blockquote class="text-stone-600 italic text-sm mb-6 relative">
                  "${member.quote}"
                </blockquote>
                <p class="text-xs text-stone-500 leading-relaxed font-sans border-t border-stone-100 pt-4">
                  ${member.description}
                </p>
              </div>
            </div>
          `).join('');
        }
        
        // 4. Re-render History Chronologie
        const historyContainer = document.getElementById('history-container');
        if (historyContainer && data.historie && Array.isArray(data.historie)) {
          historyContainer.innerHTML = data.historie.map((milestone: any) => `
            <div class="relative group">
              <div class="absolute -left-[45px] sm:-left-[61px] top-1.5 w-6 h-6 rounded-full bg-[#121315] border-2 border-[#ff4c00] flex items-center justify-center group-hover:bg-[#ff4c00] transition-colors duration-300">
                <div class="w-2 h-2 rounded-full bg-[#ff4c00] group-hover:bg-white transition-colors duration-300"></div>
              </div>
              <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-6 mb-2">
                <span class="text-3xl font-serif font-black text-[#ff4c00] leading-none">${milestone.year}</span>
                <h4 class="text-xl font-bold text-white">${milestone.title}</h4>
              </div>
              <p class="text-stone-400 text-sm leading-relaxed max-w-2xl">${milestone.description}</p>
            </div>
          `).join('');
        }
        
        // 5. Re-render jobs list
        const jobsContainer = document.getElementById('jobs-container');
        if (jobsContainer && data.jobs && Array.isArray(data.jobs)) {
          jobsContainer.innerHTML = data.jobs.map((job: any) => {
            const reqs = Array.isArray(job.requirements) ? job.requirements : [];
            const requirementsHtml = reqs.map((req: any) => `
              <li class="text-sm text-stone-700 flex items-start gap-3">
                <svg class="w-5 h-5 text-stone-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>${req}</span>
              </li>
            `).join('');

            const bens = Array.isArray(job.benefits) ? job.benefits : [];
            const benefitsHtml = bens.map((benefit: any) => `
              <li class="text-sm text-stone-700 flex items-start gap-3">
                <svg class="w-5 h-5 text-emerald-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span>${benefit}</span>
              </li>
            `).join('');

            return `
              <div class="bg-white border border-stone-200 rounded-3xl p-8 sm:p-12 hover:shadow-md transition-luxury">
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 border-b border-stone-100 pb-8 mb-8">
                  <div>
                    <span class="inline-block px-3 py-1 bg-stone-100 text-stone-600 text-[10px] font-mono uppercase tracking-wider rounded-full mb-3">
                      ${job.type}
                    </span>
                    <h3 class="text-2xl font-bold text-stone-900">${job.title}</h3>
                  </div>
                  <a 
                    href="mailto:info@john-haustechnik.de?subject=Bewerbung%20als%20${encodeURIComponent(job.title)}"
                    class="inline-flex items-center justify-center px-6 h-12 bg-[#ff4c00] hover:bg-[#ff4c00]/90 text-white font-bold text-xs uppercase tracking-widest rounded-full transition-all duration-300"
                  >
                    Jetzt formlos bewerben
                  </a>
                </div>

                <p class="text-stone-600 text-sm mb-8 leading-relaxed max-w-3xl">
                  ${job.intro}
                </p>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
                  <div>
                    <h4 class="text-xs font-mono uppercase tracking-wider text-stone-400 mb-4 font-bold">Was Sie mitbringen:</h4>
                    <ul class="space-y-3">
                      ${requirementsHtml}
                    </ul>
                  </div>
                  <div>
                    <h4 class="text-xs font-mono uppercase tracking-wider text-[#ff4c00] mb-4 font-bold">Was wir bieten:</h4>
                    <ul class="space-y-3">
                      ${benefitsHtml}
                    </ul>
                  </div>
                </div>
              </div>
            `;
          }).join('');
        }
        
      } catch (err) {
        console.error("Fehler beim Verarbeiten des lokalen CMS-Caches auf der Startseite:", err);
      }
    }
  </script>
</Layout>
