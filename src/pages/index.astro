---
export const prerender = true;
import Base from '../layouts/Base.astro';

const leistungen = [
  { slug: 'sanitaer', titel: 'Sanitär', img: 'sanitaer', text: 'Barrierefreie Bäder, Duschen, Armaturen — geplant wie für die eigene Familie.' },
  { slug: 'wasser', titel: 'Wasser', img: 'wasser', text: 'Versorgung, Aufbereitung, Gartenbewässerung — sauber installiert, sicher.' },
  { slug: 'heizung', titel: 'Heizung', img: 'heizung', text: 'Wärmepumpe, Brennwert, Pellets, Solar — effizient heizen, Förderung inklusive.' },
  { slug: 'gas', titel: 'Gas', img: 'gas', text: 'Gasanlagen, Hausanschluss, Sicherheitstechnik — geprüft und zuverlässig.' },
  { slug: 'klima-lueftung', titel: 'Klima & Lüftung', img: 'lueftung', text: 'Split-Klima, Wohnraumlüftung, Wärmerückgewinnung — spürbar besseres Raumklima.' },
  { slug: 'solar', titel: 'Solar', img: 'solar', text: 'Photovoltaik, Solarthermie, Warmwasser — die Sonne für dich arbeiten lassen.' },
];

const schritte = [
  { nr: '01', titel: 'Beratung', text: 'Wir hören zu und zeigen ehrlich, was möglich ist — vor Ort oder am Telefon.' },
  { nr: '02', titel: 'Planung', text: 'Maßgeschneidert, mit Blick aufs Budget und auf Förderungen, die dir zustehen.' },
  { nr: '03', titel: 'Umsetzung', text: 'Sauber und termintreu, mit festem Ansprechpartner — bis alles läuft.' },
];

const fakten = [
  { zahl: '45+', label: 'Jahre Erfahrung' },
  { zahl: '3.', label: 'Generation' },
  { zahl: '~15', label: 'Kolleg:innen' },
  { zahl: '6', label: 'Gewerke' },
];

const team = [
  { name: 'Paul Band', rolle: 'Geschäftsführung' },
  { name: 'Patrick Band', rolle: 'Geschäftsführung' },
  { name: 'Dein Meister', rolle: 'Anlagenmechaniker SHK' },
  { name: 'Nachwuchs', rolle: 'Auszubildende:r' },
];

const jobs = [
  { titel: 'Anlagenmechaniker SHK (m/w/d)', typ: 'Vollzeit · Unbefristet' },
  { titel: 'Servicetechniker / Kundendienst (m/w/d)', typ: 'Vollzeit · Unbefristet' },
];

const faqs = [
  { f: 'Was kostet eine Erstberatung?', a: 'Das Erstgespräch ist unverbindlich. Wir schauen uns dein Vorhaben an und sagen ehrlich, was möglich ist.' },
  { f: 'Kümmert ihr euch um Förderungen (Wärmepumpe, BAFA, KfW)?', a: 'Ja. Wir planen förderfähig und unterstützen bei den Anträgen — damit du das Maximum mitnimmst.' },
  { f: 'Wie schnell bekomme ich einen Termin?', a: 'In der Regel kurzfristig. Für Notfälle haben wir einen Notdienst — ruf einfach an.' },
  { f: 'Welche Gebiete deckt ihr ab?', a: 'Ludwigsfelde und Umgebung (Teltow-Fläming). Frag gern nach, ob wir zu dir kommen.' },
];

const inputCls = "w-full bg-paper border border-ink/15 rounded-lg px-4 py-3.5 text-ink placeholder:text-mute focus:border-john-blue outline-none transition-colors";
---
<Base>
  <!-- TOP BAR -->
  <header class="fixed top-0 inset-x-0 z-50 mix-blend-difference text-white">
    <div class="flex items-center justify-between px-5 sm:px-8 py-5">
      <a href="/" class="font-display text-xl tracking-tight leading-none">JOHN</a>
      <button id="menu-btn" class="hidden sm:flex items-center gap-2 text-[11px] font-bold uppercase tracking-[0.2em]">
        Menü
        <span class="flex flex-col gap-[3px]"><span class="block w-4 h-px bg-current"></span><span class="block w-4 h-px bg-current"></span></span>
      </button>
      <a href="#kontakt" class="text-[11px] font-bold uppercase tracking-[0.2em] border-b border-current pb-0.5">Anfrage</a>
    </div>
  </header>

  <!-- HERO -->
  <section class="relative min-h-svh flex flex-col justify-between overflow-hidden">
    <!-- Intro line -->
    <div class="pt-28 sm:pt-32 px-5 sm:px-8 flex justify-end">
      <p data-reveal class="max-w-sm text-right text-sm sm:text-base font-medium leading-snug text-ink/80">
        <span class="inline-block w-2 h-2 bg-john-red align-middle mr-2"></span>
        Mehr als Rohre und Technik. Handwerk von Menschen, die seit&nbsp;1979 dafür einstehen — Bad, Heizung & Solar in Ludwigsfelde.
      </p>
    </div>

    <!-- Giant wordmark -->
    <div class="px-3 sm:px-5 -mb-[1.5vw]">
      <h1 id="wordmark" class="font-display leading-[0.78] tracking-[-0.05em] text-[27vw] select-none">
        <span class="text-john-blue">JOH</span><span class="text-john-red">N</span>
      </h1>
    </div>

    <!-- Corner labels -->
    <div class="flex items-end justify-between px-5 sm:px-8 pb-5 text-[10px] sm:text-[11px] font-mono uppercase tracking-[0.2em] text-mute">
      <span>EST. 1979</span>
      <span class="flex items-center gap-2"><span class="hidden sm:inline">Scrollen</span><span class="block w-px h-6 bg-mute/50 animate-pulse"></span></span>
      <span>Ludwigsfelde</span>
    </div>
  </section>

  <!-- FULL-SCREEN IMAGE -->
  <section class="relative min-h-svh w-full overflow-hidden bg-ink">
    <img src="/img/hero.jpg" alt="Handschlag zweier Handwerker" class="absolute inset-0 w-full h-full object-cover will-change-transform" id="hero-img" />
    <div class="absolute inset-0 bg-gradient-to-t from-ink/70 via-ink/10 to-transparent"></div>
    <div class="relative z-10 min-h-svh flex flex-col justify-end px-5 sm:px-8 pb-16 sm:pb-24 text-white">
      <p data-reveal class="text-[11px] font-bold uppercase tracking-[0.3em] text-john-red mb-4">Anpacken statt versprechen</p>
      <h2 data-reveal class="font-display text-[9vw] sm:text-[6vw] leading-[0.92] max-w-5xl">
        Handwerk von Menschen,<br/>die dafür einstehen.
      </h2>
    </div>
  </section>

  <!-- LEISTUNGEN -->
  <section id="leistungen" class="px-5 sm:px-8 py-24 sm:py-36">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-14 sm:mb-20">
        <div data-reveal>
          <p class="text-[11px] font-bold uppercase tracking-[0.3em] text-john-red mb-4">Unser Handwerk</p>
          <h2 class="font-display text-[12vw] sm:text-[5.5vw] leading-[0.9]">Sechs Gewerke.<br/>Eine&nbsp;Hand.</h2>
        </div>
        <p data-reveal class="max-w-xs text-mute text-sm sm:text-base leading-relaxed sm:text-right">
          Von Bad bis Solar — alles aus einem Haus, von Menschen, die ihr Fach lieben.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-12">
        {leistungen.map((l) => (
          <a href={`/leistungen/${l.slug}`} class="group block" data-reveal>
            <div class="overflow-hidden rounded-xl aspect-[4/3] mb-5 bg-ink/5">
              <img src={`/img/${l.img}.jpg`} alt={l.titel} loading="lazy"
                   class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.06]" />
            </div>
            <div class="flex items-baseline justify-between gap-3">
              <h3 class="font-display text-2xl sm:text-[1.7rem] leading-none">{l.titel}</h3>
              <span class="text-john-red text-lg transition-transform duration-300 group-hover:translate-x-1.5">→</span>
            </div>
            <p class="text-mute text-sm mt-2 leading-snug">{l.text}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- SO ARBEITEN WIR -->
  <section id="ablauf" class="px-5 sm:px-8 py-24 sm:py-36 border-t border-ink/10">
    <div class="max-w-7xl mx-auto">
      <div class="mb-14 sm:mb-20 max-w-3xl" data-reveal>
        <p class="text-[11px] font-bold uppercase tracking-[0.3em] text-john-red mb-4">So arbeiten wir</p>
        <h2 class="font-display text-[11vw] sm:text-[5vw] leading-[0.92]">Von der Idee bis zur<br/>letzten&nbsp;Schraube.</h2>
        <p class="mt-6 text-mute max-w-xl leading-relaxed">Ein Ansprechpartner begleitet dich vom ersten Gespräch bis zur Abnahme — alles aus einer Hand.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8">
        {schritte.map((s) => (
          <div class="border-t-2 border-john-blue pt-5" data-reveal>
            <span class="font-display text-john-blue text-5xl block mb-3 leading-none">{s.nr}</span>
            <h3 class="font-display text-2xl mb-2">{s.titel}</h3>
            <p class="text-mute text-sm leading-relaxed">{s.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WARUM JOHN (dunkel) -->
  <section id="warum" class="px-5 sm:px-8 py-24 sm:py-36 bg-ink text-white">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div data-reveal>
        <p class="text-[11px] font-bold uppercase tracking-[0.3em] text-john-red mb-4">Warum JOHN</p>
        <h2 class="font-display text-[11vw] sm:text-[4.6vw] leading-[0.95] mb-6">Seit 1979<br/>Familiensache.</h2>
        <p class="text-white/70 max-w-lg leading-relaxed">
          Gegründet 1979 von Bodo John, heute in dritter Generation von Paul & Patrick Band geführt — als Innungsbetrieb mit festen Partnern wie Bosch und Viessmann. Handwerk, das man sich die Hand drauf gibt.
        </p>
        <div class="flex flex-wrap gap-x-6 gap-y-2 mt-8 text-xs text-white/50 font-mono uppercase tracking-[0.15em]">
          <span>Innungsbetrieb</span><span>·&nbsp;&nbsp;Bosch</span><span>·&nbsp;&nbsp;Viessmann</span>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-px bg-white/10 rounded-xl overflow-hidden" data-reveal>
        {fakten.map((f) => (
          <div class="bg-ink p-8 sm:p-10">
            <span class="font-display text-5xl sm:text-6xl block leading-none">{f.zahl}</span>
            <span class="text-white/45 text-sm mt-3 block">{f.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section id="team" class="px-5 sm:px-8 py-24 sm:py-36 border-t border-ink/10">
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-8 lg:items-end mb-12 sm:mb-16">
        <div data-reveal>
          <p class="text-[11px] font-bold uppercase tracking-[0.3em] text-john-red mb-4">Menschen hinter dem Service</p>
          <h2 class="font-display text-[11vw] sm:text-[5vw] leading-[0.92]">Echte Gesichter,<br/>kein&nbsp;Callcenter.</h2>
        </div>
        <p data-reveal class="text-mute max-w-md leading-relaxed lg:text-right lg:justify-self-end">
          Vom Meister bis zum Azubi — bei JOHN weißt du, wer bei dir vor Ort steht.
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6">
        {team.map((m) => (
          <div data-reveal>
            <div class="aspect-[3/4] rounded-xl bg-gradient-to-b from-ink/10 to-ink/5 mb-4 flex items-end justify-center relative overflow-hidden">
              <span class="font-mono text-[10px] uppercase tracking-widest text-mute/60 mb-4">Foto folgt</span>
            </div>
            <h3 class="font-display text-lg sm:text-xl leading-tight">{m.name}</h3>
            <p class="text-mute text-xs sm:text-sm mt-0.5">{m.rolle}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- KARRIERE (blau) -->
  <section id="karriere" class="px-5 sm:px-8 py-24 sm:py-36 bg-john-blue text-white">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 lg:gap-20">
      <div data-reveal>
        <p class="text-[11px] font-bold uppercase tracking-[0.3em] text-white/70 mb-4">Karriere bei JOHN</p>
        <h2 class="font-display text-[13vw] sm:text-[5.5vw] leading-[0.88] mb-6">Komm ins<br/>Team.</h2>
        <p class="text-white/80 max-w-md leading-relaxed">Modern, jung und kompetent — ohne Baustellenhektik. Bei uns lernst du, wächst du, und bist abends zu Hause: keine Fernmontage, nur regionale Einsätze.</p>
        <p class="mt-6 inline-flex items-center gap-2 text-sm font-bold"><span class="w-2 h-2 bg-john-red inline-block"></span> Bewerbung ohne Anschreiben.</p>
      </div>
      <div class="space-y-4" data-reveal>
        {jobs.map((j) => (
          <a href="/karriere" class="group flex items-center justify-between gap-4 bg-white/10 hover:bg-white/[0.16] transition-colors rounded-xl p-6">
            <div>
              <h3 class="font-display text-lg sm:text-xl leading-tight">{j.titel}</h3>
              <p class="text-white/60 text-sm mt-1">{j.typ}</p>
            </div>
            <span class="text-john-red text-xl shrink-0 transition-transform group-hover:translate-x-1.5">→</span>
          </a>
        ))}
        <a href="/karriere" class="inline-flex items-center gap-2 mt-2 text-sm font-bold uppercase tracking-[0.15em] border-b border-white/40 pb-1">Alle Stellen ansehen →</a>
      </div>
    </div>
  </section>

  <!-- KONTAKT + MAP -->
  <section id="kontakt" class="px-5 sm:px-8 py-24 sm:py-36 border-t border-ink/10">
    <div class="max-w-7xl mx-auto">
      <div class="mb-12 sm:mb-16 max-w-2xl" data-reveal>
        <p class="text-[11px] font-bold uppercase tracking-[0.3em] text-john-red mb-4">Kontakt</p>
        <h2 class="font-display text-[12vw] sm:text-[5.5vw] leading-[0.9]">Sprich mit einem<br/>echten&nbsp;Menschen.</h2>
      </div>
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16">
        <form class="space-y-5" data-reveal onsubmit="return false">
          <div class="grid sm:grid-cols-2 gap-5">
            <input type="text" placeholder="Name" class={inputCls} />
            <input type="tel" placeholder="Telefon" class={inputCls} />
          </div>
          <select class={inputCls}>
            <option>Anliegen wählen…</option>
            <option>Bad / Sanitär</option><option>Heizung / Wärmepumpe</option>
            <option>Klima &amp; Lüftung</option><option>Solar</option>
            <option>Notdienst</option><option>Sonstiges</option>
          </select>
          <textarea rows="4" placeholder="Worum geht's?" class={inputCls}></textarea>
          <button type="submit" class="inline-flex items-center gap-2 bg-john-blue hover:bg-john-blue-deep transition-colors text-white font-bold rounded-lg px-7 py-3.5">Anfrage senden →</button>
        </form>
        <div data-reveal>
          <div class="space-y-1 mb-6">
            <p class="font-display text-2xl mb-2">Firma JOHN</p>
            <p class="text-mute">Dornweg 14 · 14974 Ludwigsfelde</p>
            <p><a href="tel:0337851210" class="text-john-blue font-bold hover:underline">03378 51 12 10</a></p>
            <p class="text-mute">info@firma-john.de</p>
          </div>
          <div class="aspect-[16/10] rounded-xl bg-ink/5 border border-ink/10 flex items-center justify-center">
            <span class="font-mono text-[11px] uppercase tracking-widest text-mute text-center px-4">Karte · Ludwigsfelde<br/>(DSGVO: Klick zum Laden)</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="px-5 sm:px-8 py-24 sm:py-36 border-t border-ink/10">
    <div class="max-w-3xl mx-auto">
      <div class="mb-12" data-reveal>
        <p class="text-[11px] font-bold uppercase tracking-[0.3em] text-john-red mb-4">Häufige Fragen</p>
        <h2 class="font-display text-[13vw] sm:text-[5vw] leading-[0.9]">Gut zu wissen.</h2>
      </div>
      <div class="border-t border-ink/10" data-reveal>
        {faqs.map((q) => (
          <details class="group border-b border-ink/10 py-5">
            <summary class="flex items-center justify-between gap-4 cursor-pointer list-none font-display text-lg sm:text-xl">
              {q.f}
              <span class="text-john-red text-2xl shrink-0 transition-transform duration-300 group-open:rotate-45">+</span>
            </summary>
            <p class="text-mute mt-3 leading-relaxed">{q.a}</p>
          </details>
        ))}
      </div>
      <a href="/faq" class="inline-flex items-center gap-2 mt-8 text-sm font-bold uppercase tracking-[0.15em] text-john-blue border-b border-john-blue/30 pb-1">Alle Fragen →</a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-ink text-white px-5 sm:px-8 pt-20 pb-8">
    <div class="max-w-7xl mx-auto">
      <div class="grid md:grid-cols-3 gap-10 mb-16">
        <div>
          <p class="font-display text-3xl mb-4 leading-none"><span class="text-john-blue">JOH</span><span class="text-john-red">N</span></p>
          <p class="text-white/45 text-sm max-w-xs leading-relaxed">Meisterbetrieb für Sanitär, Heizung, Klima & Solar in Ludwigsfelde. Seit 1979, in dritter Generation.</p>
        </div>
        <div class="text-sm text-white/60 space-y-1.5">
          <p class="text-white/35 uppercase text-[10px] tracking-[0.2em] mb-3">Kontakt</p>
          <p>Dornweg 14, 14974 Ludwigsfelde</p>
          <p><a href="tel:0337851210" class="hover:text-white transition-colors">03378 51 12 10</a></p>
          <p>info@firma-john.de</p>
        </div>
        <div class="text-sm text-white/60 space-y-1.5">
          <p class="text-white/35 uppercase text-[10px] tracking-[0.2em] mb-3">Seite</p>
          <a class="block hover:text-white transition-colors" href="#leistungen">Leistungen</a>
          <a class="block hover:text-white transition-colors" href="#warum">Unternehmen</a>
          <a class="block hover:text-white transition-colors" href="#karriere">Karriere</a>
          <a class="block hover:text-white transition-colors" href="#kontakt">Kontakt</a>
        </div>
      </div>
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 pt-6 border-t border-white/10 text-xs text-white/40">
        <span>© 2026 p&p hauswerk GmbH · Innungsbetrieb SHK</span>
        <div class="flex gap-6"><a href="/impressum" class="hover:text-white transition-colors">Impressum</a><a href="/datenschutz" class="hover:text-white transition-colors">Datenschutz</a></div>
      </div>
    </div>
  </footer>

  <script>
    import Lenis from 'lenis';
    import { animate } from 'motion';

    // Smooth scroll
    const lenis = new Lenis({ duration: 1.1, easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
    function raf(time: number) { lenis.raf(time); requestAnimationFrame(raf); }
    requestAnimationFrame(raf);

    // Reveal-on-scroll (IntersectionObserver = robust)
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          animate(e.target, { opacity: [0, 1], y: [28, 0] }, { duration: 0.8, ease: [0.16, 1, 0.3, 1] });
          io.unobserve(e.target);
        }
      }
    }, { rootMargin: '0px 0px -12% 0px' });
    document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));

    // Subtiler Parallax: Hero-Bild leicht mitziehen
    const img = document.getElementById('hero-img');
    if (img) {
      lenis.on('scroll', ({ scroll }: { scroll: number }) => {
        img.style.transform = `translateY(${scroll * 0.08}px) scale(1.05)`;
      });
    }
  </script>
</Base>
