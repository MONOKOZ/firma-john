# ── Google Sheets (Build-Read via Service Account) ───────────────────────────
# SHEET_ID: aus der Sheet-URL .../spreadsheets/d/<SHEET_ID>/edit  (kein Geheimnis)
SHEET_ID="DEINE_SHEET_ID"

# Variante A (lokal/Dev): Pfad zur gitignorierten Service-Account-JSON
GOOGLE_SA_KEY_FILE=".secrets/service-account.json"

# Variante B (Cloudflare/CI): komplette JSON als base64 in EINER Env-Variable
# GOOGLE_SA_KEY_BASE64="..."

# Variante C: einzeln (private key mit \n-Escapes, in Anführungszeichen)
# GOOGLE_SA_EMAIL="...@...iam.gserviceaccount.com"
# GOOGLE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
